services:
  nginx:
    build: .
    container_name: {{ role_name }}
    networks:
      - nginx_reverse_proxy
    ports:
      - "80:80"
      - "443:443"
      - "1667:1667"
    volumes:
      - /etc/docker/soju/sock:/run/soju
      - ./letsencrypt:/etc/letsencrypt
      - ./nginx.conf:/etc/nginx/nginx.conf
      - ./conf.d:/etc/nginx/conf.d
      - ./stream.d:/etc/nginx/stream.d

networks:
  nginx_reverse_proxy:
    external: true