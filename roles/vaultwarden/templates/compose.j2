services:
  vaultwarden:
    image: vaultwarden/server:{{ vaultwarden_version }}
    container_name: {{ role_name }}
    restart: unless-stopped
    user: {{ vaultwarden_uid }}:{{ vaultwarden_gid }}
    environment:
      DOMAIN: "https://vw.{{ domain }}"
      SHOW_PASSWORD_HINT: false
      EXTENDED_LOGGING: true
      LOG_FILE: "/data/vaultwarden.log"
    volumes:
      - ./data/:/data/
    #ports:
    #  - 127.0.0.1:8000:80
    networks:
      - nginx_reverse_proxy

networks:
  nginx_reverse_proxy:
    external: true
