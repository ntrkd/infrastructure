upstream traefik {
    zone traefik 64k;
    resolver 127.0.0.11 valid=10s ipv6=off;
    server dokploy-traefik:80 resolve;
    keepalive 2;
}

server {
    listen 80;
    listen [::]:80;
    server_name *.ad.{{ domain }};

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name *.ad.{{ domain }};

    ssl_certificate /etc/nginx/certs/live/ad.{{ domain }}/cert.pem;
    ssl_certificate_key /etc/nginx/certs/live/ad.{{ domain }}/key.pem;
    ssl_dhparam /etc/nginx/certs/ssl-dhparams.pem;

    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    location / {
        proxy_pass http://traefik;
    }
}